{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-checkpoint.sh"
          },
          {
            "type": "command",
            "if": "Bash(git reset --hard*)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-checkpoint.sh"
          },
          {
            "type": "command",
            "if": "Bash(git checkout *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
