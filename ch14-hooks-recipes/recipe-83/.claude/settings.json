{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/.env)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-secret-files.sh"
          },
          {
            "type": "command",
            "if": "Edit(**/credentials.json)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-secret-files.sh"
          },
          {
            "type": "command",
            "if": "Edit(**/*.pem)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-secret-files.sh"
          },
          {
            "type": "command",
            "if": "Edit(**/*.key)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-secret-files.sh"
          }
        ]
      }
    ]
  }
}
