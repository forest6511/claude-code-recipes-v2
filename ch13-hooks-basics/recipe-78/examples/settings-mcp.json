{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__memory__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/log-memory.sh" }
        ]
      },
      {
        "matcher": "mcp__.*__write.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-mcp-write.sh" }
        ]
      }
    ]
  }
}
